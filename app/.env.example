# Copy to .env.local and fill in. For on-prem, point at the university's own stack.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# LLM gateway (on-prem vLLM / Ollama-compatible OpenAI endpoint). Blank = built-in stub replies.
VITE_LLM_CAMPUS_ENDPOINT=
VITE_LLM_WORLD_ENDPOINT=

# Custom OpenAI-compatible gateway for LOCAL DEV (e.g. AICredits → DeepSeek V4
# Flash). When base + key are set, the app streams directly from here for every
# mode. WARNING: a VITE_ key is inlined into the browser bundle — only use this
# for local dev. For the hosted site leave these blank and set AICREDITS_API_KEY
# as a Supabase secret so the `chat` edge function holds the key server-side.
VITE_AI_BASE_URL=https://aicredits.in/v1
VITE_AI_API_KEY=
VITE_AI_MODEL=deepseek/deepseek-v4-flash
