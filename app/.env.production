VITE_SUPABASE_ANON_KEY=sb_publishable_soHegVbA7TCZ-ivucBg9ag_syAr78Oh
VITE_STUDENT_EMAIL_DOMAIN=students.merzal.local
# NOTE: this key ships in the public JS bundle. Rotate before public launch
# (or move to the Supabase edge-function path so the key stays server-side).
VITE_GEMINI_API_KEY=AIzaSyBZO0upy6RJc2H1pUaRgKZRhq_gKKhLBbs
VITE_GEMINI_MODEL=gemma-4-31b-it,gemini-2.5-flash,gemini-2.0-flash
